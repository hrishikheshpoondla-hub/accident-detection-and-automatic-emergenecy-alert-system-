<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_vanguard">

    <!-- Subtle Glow Background Decoration -->
    <View
        android:id="@+id/pulseBackground"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/circle_gradient_warning"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.25"/>

    <!-- Status Header -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/systemStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CRITICAL ALERT"
            android:textColor="@color/vanguard_sos_red"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.2"/>

        <ImageView
            android:id="@+id/statusIndicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/status_indicator_animated"
            app:tint="@color/vanguard_sos_red"/>
    </LinearLayout>

    <!-- Alert Context Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/alertCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/vanguard_card"
        app:strokeWidth="1dp"
        app:strokeColor="@color/vanguard_sos_red"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toTopOf="@id/cancelButton"
        app:layout_constraintVertical_bias="0.35">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="40dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INITIATING TELEMETRY SOS"
                android:textColor="@color/vanguard_text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"/>

            <!-- High-Tech Countdown -->
            <FrameLayout
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="24dp">

                <ProgressBar
                    android:id="@+id/countdownProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:progress="100"
                    android:max="100"
                    android:progressDrawable="@drawable/countdown_progress" />

                <TextView
                    android:id="@+id/countdownText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="10"
                    android:textColor="@color/vanguard_text_primary"
                    android:textSize="80sp"
                    android:fontFamily="monospace"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="seconds until alert"
                android:textColor="@color/vanguard_text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-light"/>

            <!-- Notification Tray Mockup -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/vanguard_glass_overlay"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="@color/vanguard_text_primary"/>

                <TextView
                    android:id="@+id/contactsInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Transmitting to 5 contacts"
                    android:textColor="@color/vanguard_text_primary"
                    android:textSize="13sp"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- High-Impact Cancel Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancelButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:text="IGNORE ALERT — I AM SAFE"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/vanguard_text_primary"
        android:letterSpacing="0.1"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/vanguard_card_high"
        app:strokeColor="@color/vanguard_cyan_primary"
        app:strokeWidth="1dp"
        app:rippleColor="#2600E5FF"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="48dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
